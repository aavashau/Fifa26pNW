# Copy to .env and fill in your values

SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ADMIN_EMAIL=your.email@gmail.com

# Gmail SMTP — requires an App Password (not your regular Gmail password)
# Steps: Google Account → Security → 2-Step Verification ON → App Passwords → generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Google Sheets
# 1. Create a Google Cloud project → enable Sheets API + Drive API
# 2. Create a Service Account → download JSON key
# 3. Create a new Google Sheet → share it with the service account email (Editor)
# 4. Copy the Sheet ID from the URL (the long string between /d/ and /edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# For local dev: set path to your downloaded service account JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json

# For Railway deploy: paste the entire JSON content of the credentials file here
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":...}

# Base URL for email links (update to your Railway URL after deploy)
BASE_URL=http://localhost:8000
